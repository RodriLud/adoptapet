<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/espacio_medio"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/color_borde"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/espacio_medio">

        <TextView
            android:id="@+id/txtPetName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Solicitud para Luna"
            android:textColor="@color/color_texto"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtApplicant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Solicitante: María López"
            android:textColor="@color/color_texto_secundario"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Fecha: 06/06/2026"
            android:textColor="@color/color_texto_secundario"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_pequeno"
            android:background="@color/color_principal_claro"
            android:padding="8dp"
            android:text="Pendiente"
            android:textColor="@color/color_principal"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>