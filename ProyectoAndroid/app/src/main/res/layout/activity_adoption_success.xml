<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_fondo">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/espacio_grande">

        <TextView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:background="@color/color_principal_claro"
            android:gravity="center"
            android:text="✓"
            android:textColor="@color/color_principal"
            android:textSize="64sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtTituloSuccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_grande"
            android:gravity="center"
            android:text="¡Solicitud enviada!"
            android:textColor="@color/color_texto"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMensajeSuccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_pequeno"
            android:gravity="center"
            android:text="Tu solicitud de adopción fue enviada correctamente. Pronto revisaremos tu información."
            android:textColor="@color/color_texto_secundario"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_grande"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/color_borde"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/espacio_medio">

                <TextView
                    android:id="@+id/txtMascotaSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mascota: Luna"
                    android:textColor="@color/color_texto"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtEstadoSuccess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/espacio_pequeno"
                    android:text="Estado: Pendiente de revisión"
                    android:textColor="@color/color_principal"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVolverInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_grande"
            android:text="Volver al inicio"
            android:textAllCaps="false"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerSolicitudes"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/espacio_pequeno"
            android:text="Ver mis solicitudes"
            android:textAllCaps="false"
            app:cornerRadius="24dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>